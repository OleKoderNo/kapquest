generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CharacterClass {
  WARRIOR
  MAGE
  ROUGE
  HEALER
}

model User {
  id        String      @id @default(cuid())
  email     String?     @unique
  name      String?
  image     String?

  characters Character[]

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Character {
  id        String         @id @default(cuid())
  name      String
  class     CharacterClass

  level     Int            @default(1)
  xp        Int            @default(0)
  gold      Int            @default(0)

  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId])
}